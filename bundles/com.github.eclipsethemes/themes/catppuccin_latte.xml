<?xml version="1.0" encoding="utf-8"?>
<colorTheme ect-id="7c4575af-e397-46d7-a6d0-8711569a4290" id="9005" name="Catppuccin Latte" modified="2025-09-22" author="Eclipse Themes" type="light">

    <!-- CORE EDITOR COLORS -->
    <foreground color="#4c4f69" />
    <background color="#eff1f5" />
    <selectionBackground color="#cfd1d9" />
    <selectionForeground color="#4c4f69" />
    <currentLine color="#e4e6eb" />
    <lineNumber color="#8c8fa1" />

    <!-- EDITOR FEATURES & NAVIGATION -->
    <occurrence color="#d8dae1" />
    <writeOccurrence color="#d0dcf5" />
    <removedLine color="#d20f39" />
    <findScope color="#e6e9ef" />
    <searchResult color="#e6adbd" />
    <filteredSearchResult color="#a9daf0" />

    <!-- BASIC SYNTAX ELEMENTS -->
    <comment color="#7c7f93" />
    <multiLineComment color="#7c7f93" italic="true" />
    <taskTag color="#8839ef" bold="true" />
    <keyword color="#8839ef" />
    <number color="#fe640b" />
    <string color="#40a02b" />
    <bracket color="#7c7f93" />
    <operator color="#179299" />

    <!-- OBJECT-ORIENTED CONSTRUCTS -->
    <class color="#df8e1d" italic="true" />
    <abstractClass color="#df8e1d" italic="true" />
    <interface color="#df8e1d" italic="true" />
    <enum color="#df8e1d" italic="true" />
    <annotation color="#fe640b" />

    <!-- METHODS & FUNCTIONS -->
    <method color="#1e66f5" italic="true" />
    <staticMethod color="#1e66f5" italic="true" />
    <abstractMethod color="#1e66f5" italic="true" />
    <inheritedMethod color="#1e66f5" italic="true" />
    <methodDeclaration color="#1e66f5" italic="true" />

    <!-- VARIABLES & FIELDS -->
    <field color="#4c4f69" />
    <staticField color="#4c4f69" italic="true" />
    <constant color="#fe640b" bold="true" italic="true" />
    <localVariable color="#4c4f69" />
    <localVariableDeclaration color="#4c4f69" />
    <argument color="#e64553" italic="true" />

    <!-- GENERIC PROGRAMMING -->
    <templateParameter color="#04a5e5" />
    <templateArgument color="#04a5e5" />

    <!-- DOCUMENTATION -->
    <doc color="#7c7f93" italic="true" />
    <docTag color="#8839ef" />
    <docLink color="#1e66f5" />
    <docXmlTag color="#8839ef" bold="true" />

    <!-- SPECIAL STATES -->
    <deprecated color="#4c4f69" strikethrough="true" />

    <!-- LANGUAGE-SPECIFIC: XML -->
    <xmlTag color="#1e66f5" />
    <xmlAttribute color="#df8e1d" />

