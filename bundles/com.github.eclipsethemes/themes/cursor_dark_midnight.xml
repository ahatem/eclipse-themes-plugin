<?xml version="1.0" encoding="utf-8"?>
<colorTheme ect-id="79069d33-2ffc-48a9-a478-a8a1e75f1421" id="9003" name="Cursor Dark Midnight" modified="2025-09-22" author="Eclipse Themes" type="dark">

    <!-- CORE EDITOR COLORS -->
    <foreground color="#7b88a1" />
    <background color="#1e2127" />
    <selectionBackground color="#343B48" />
    <selectionForeground color="#eceff4" />
    <currentLine color="#252A32" />
    <lineNumber color="#4c566a" />

    <!-- EDITOR FEATURES & NAVIGATION -->
    <occurrence color="#465465" />
    <writeOccurrence color="#596E83" />
    <removedLine color="#bf616a" />
    <findScope color="#20242c" />
    <searchResult color="#48616B" />
    <filteredSearchResult color="#334149" />

    <!-- BASIC SYNTAX ELEMENTS -->
    <comment color="#636E85" />
    <multiLineComment color="#636E85" italic="true" />
    <taskTag color="#A3BE8C" bold="true" />
    <keyword color="#81A1C1" />
    <number color="#B48EAD" />
    <string color="#A3BE8C" />
    <bracket color="#ECEFF4" />
    <operator color="#81A1C1" />

    <!-- OBJECT-ORIENTED CONSTRUCTS -->
    <class color="#8FBCBB" />
    <abstractClass color="#8FBCBB" />
    <interface color="#8FBCBB" />
    <enum color="#8FBCBB" />
    <annotation color="#D08770" />

    <!-- METHODS & FUNCTIONS -->
    <method color="#88C0D0" />
    <staticMethod color="#88C0D0" italic="true" />
    <abstractMethod color="#88C0D0" />
    <inheritedMethod color="#88C0D0" />
    <methodDeclaration color="#88C0D0" />

    <!-- VARIABLES & FIELDS -->
    <field color="#D8DEE9" />
    <staticField color="#D8DEE9" italic="true" />
    <constant color="#D8DEE9" bold="true" italic="true" />
    <localVariable color="#D8DEE9" />
    <localVariableDeclaration color="#D8DEE9" />
    <argument color="#D8DEE9" />

    <!-- GENERIC PROGRAMMING -->
    <templateParameter color="#8FBCBB" />
    <templateArgument color="#8FBCBB" />

    <!-- DOCUMENTATION -->
    <doc color="#636E85" italic="true" />
    <docTag color="#81A1C1" />
    <docLink color="#8fbcbb" />
    <docXmlTag color="#8FBCBB" bold="true" />

    <!-- SPECIAL STATES -->
    <deprecated color="#EBCB8B" strikethrough="true" />

    <!-- LANGUAGE-SPECIFIC: XML -->
    <xmlTag color="#81A1C1" />
    <xmlAttribute color="#8FBCBB" italic="true" />

</colorTheme>