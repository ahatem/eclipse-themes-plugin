    <docLink color="#3794ff" />
    <docXmlTag color="#79c0ff" bold="true" />

    <!-- SPECIAL STATES -->
    <deprecated color="#ffa198" strikethrough="true" />

    <!-- LANGUAGE-SPECIFIC: XML -->
    <xmlTag color="#7ee787" />
    <xmlAttribute color="#79c0ff" />

