<?xml version="1.0" encoding="utf-8"?>
<colorTheme ect-id="884866b7-f08c-4703-a42d-20cc9ae400ec" id="9001" name="IntelliJ Light" modified="2025-09-22" author="Eclipse Themes" type="light">

    <!-- CORE EDITOR COLORS -->
    <foreground color="#080808" />
    <background color="#ffffff" />
    <selectionBackground color="#a6d2ff" />
    <selectionForeground color="#080808" />
    <currentLine color="#f4f8fe" />
    <lineNumber color="#aeb3c1" />

    <!-- EDITOR FEATURES & NAVIGATION -->
    <occurrence color="#E2E2FD" />
    <writeOccurrence color="#FFE6FF" />
    <removedLine color="#767a8a" />
    <findScope color="#ebecf0" />
    <searchResult color="#a6d2ff" />
    <filteredSearchResult color="#FEE1A3" />

    <!-- BASIC SYNTAX ELEMENTS -->
    <comment color="#8C8C8C" />
    <multiLineComment color="#8C8C8C" italic="true" />
    <taskTag color="#0133B3" bold="true" />
    <keyword color="#0133B3" />
    <number color="#1750EB" />
    <string color="#077D18" />
    <bracket color="#080808" />
    <operator color="#080808" />

    <!-- OBJECT-ORIENTED CONSTRUCTS -->
    <class color="#080808" />
    <abstractClass color="#080808" />
    <interface color="#080808" />
    <enum color="#861194" />
    <annotation color="#9E880D" />

    <!-- METHODS & FUNCTIONS -->
    <method color="#006279" />
    <staticMethod color="#006279" italic="true" />
    <abstractMethod color="#006279" />
    <inheritedMethod color="#006279" />
    <methodDeclaration color="#006279" />

    <!-- VARIABLES & FIELDS -->
    <field color="#861194" />
    <staticField color="#861194" italic="true" />
    <constant color="#861194" bold="true" italic="true" />
    <localVariable color="#238F8F" />
    <localVariableDeclaration color="#238F8F" />
    <argument color="#080808" />

    <!-- GENERIC PROGRAMMING -->
    <templateParameter color="#238F8F" />
    <templateArgument color="#238F8F" />

    <!-- DOCUMENTATION -->
    <doc color="#8C8C8C" />
    <docTag color="#0133B3" />
    <docLink color="#016DCC" underline="true" />
    <docXmlTag color="#080808" bold="true" />

    <!-- SPECIAL STATES -->
    <deprecated color="#080808" strikethrough="true" />

    <!-- LANGUAGE-SPECIFIC: XML -->
    <xmlTag color="#0133B3" />
    <xmlAttribute color="#174AD4" />

</colorTheme>