<?xml version="1.0" encoding="utf-8"?>
<colorTheme ect-id="31e54fc6-1028-40c6-85ee-a7a51fb52846" id="9008" name="Jupyter" modified="2025-09-22" author="Eclipse Themes" type="light">

    <!-- CORE EDITOR COLORS -->
    <foreground color="#212121" />
    <background color="#ffffff" />
    <selectionBackground color="#FDF0E2" />
    <selectionForeground color="#212121" />
    <currentLine color="#FDF0E2" />
    <lineNumber color="#aaaaaa" />

    <!-- EDITOR FEATURES & NAVIGATION -->
    <occurrence color="#FDF0E2" />
    <writeOccurrence color="#FDF0E2" />
    <removedLine color="#c7254e" />
    <findScope color="#FDF0E2" />
    <searchResult color="#FDF0E2" />
    <filteredSearchResult color="#FDF0E2" />

    <!-- BASIC SYNTAX ELEMENTS -->
    <comment color="#408080" />
    <multiLineComment color="#408080" italic="true" />
    <taskTag color="#008000" bold="true" />
    <keyword color="#008000" bold="true" />
    <number color="#BC7A00" />
    <string color="#BA2121" />
    <bracket color="#212121" />
    <operator color="#aa22ff" />

    <!-- OBJECT-ORIENTED CONSTRUCTS -->
    <class color="#0000FF" />
    <abstractClass color="#0000FF" />
    <interface color="#0000FF" />
    <enum color="#0000FF" />
    <annotation color="#AA22FF" />

    <!-- METHODS & FUNCTIONS -->
    <method color="#0000FF" />
    <staticMethod color="#0000FF" italic="true" />
    <abstractMethod color="#0000FF" />
    <inheritedMethod color="#0000FF" />
    <methodDeclaration color="#0000FF" />

    <!-- VARIABLES & FIELDS -->
    <field color="#212121" />
    <staticField color="#212121" italic="true" />
    <constant color="#BC7A00" bold="true" italic="true" />
    <localVariable color="#212121" />
    <localVariableDeclaration color="#212121" />
    <argument color="#212121" />

    <!-- GENERIC PROGRAMMING -->
    <templateParameter color="#0000FF" />
    <templateArgument color="#0000FF" />

    <!-- DOCUMENTATION -->
    <doc color="#408080" />
    <docTag color="#008000" />
    <docLink color="#0000FF" />
    <docXmlTag color="#008000" bold="true" />

    <!-- SPECIAL STATES -->
    <deprecated color="#212121" strikethrough="true" />

    <!-- LANGUAGE-SPECIFIC: XML -->
    <xmlTag color="#008000" bold="true" />
    <xmlAttribute color="#7D9029" />

</colorTheme>