<?xml version="1.0" encoding="utf-8"?>
<colorTheme ect-id="7c01f0b5-1467-4cee-ac86-758d21341d0d" id="4009" name="Kintsugi Dark" modified="2024-09-21" author="Ahmed Hatem" type="dark" website="https://github.com/ahatem">

    <!-- CORE EDITOR COLORS -->
    <foreground color="#dddddd" />
    <background color="#161618" />
    <selectionBackground color="#242424" />
    <selectionForeground color="#C1C1C1" />
    <currentLine color="#1d1d1c" />
    <lineNumber color="#444444" />

    <!-- EDITOR FEATURES & NAVIGATION -->
    <occurrence color="#26292d" />
    <writeOccurrence color="#31353c" />
    <removedLine color="#b38f8f" />
    <findScope color="#1b1c1f" />
    <searchResult color="#2c2f35" />
    <filteredSearchResult color="#212226" />

    <!-- BASIC SYNTAX ELEMENTS -->
    <comment color="#af9661" />
    <multiLineComment color="#af9661" />
    <taskTag color="#af9661" />
    <keyword color="#DBAD49" bold="true" />
    <number color="#819aff" />
    <string color="#98c379" />
    <bracket color="#868165" />
    <operator color="#dddddd" />

    <!-- OBJECT-ORIENTED CONSTRUCTS -->
    <class color="#939799" />
    <abstractClass color="#939799" />
    <interface color="#939799" />
    <enum color="#939799" />
    <annotation color="#678E87" />

    <!-- METHODS & FUNCTIONS -->
    <method color="#dddddd" />
    <staticMethod color="#dddddd" />
    <abstractMethod color="#dddddd" />
    <inheritedMethod color="#dddddd" />
    <methodDeclaration color="#dddddd" />

    <!-- VARIABLES & FIELDS -->
    <field color="#dddddd" />
    <staticField color="#939799" />
    <constant color="#939799" />
    <localVariable color="#dddddd" />
    <localVariableDeclaration color="#dddddd" />
    <argument color="#dddddd" />

    <!-- GENERIC PROGRAMMING -->
    <templateParameter color="#939799" />
    <templateArgument color="#939799" />

    <!-- DOCUMENTATION -->
    <doc color="#af9661" />
    <docTag color="#8A8970" />
    <docLink color="#8A8970" />
    <docXmlTag color="#8A8970" />

    <!-- SPECIAL STATES -->
    <deprecated color="#454242" strikethrough="true" />

    <!-- LANGUAGE-SPECIFIC: XML -->
    <xmlTag color="#939799" />
    <xmlAttribute color="#939799" />

</colorTheme>