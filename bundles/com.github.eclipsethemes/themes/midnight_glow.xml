<?xml version="1.0" encoding="utf-8"?>
<colorTheme ect-id="31295587-a225-4fc1-8114-aff8a63c659a" id="4010" name="Midnight Glow" modified="2024-09-21" author="Ahmed Hatem" type="dark" website="https://github.com/ahatem">

    <!-- CORE EDITOR COLORS -->
    <foreground color="#f0f6fc" />
    <background color="#0d1117" />
    <selectionBackground color="#264f78" />
    <selectionForeground color="#f0f6fc" />
    <currentLine color="#21262d" />
    <lineNumber color="#6e7681" />

    <!-- EDITOR FEATURES & NAVIGATION -->
    <occurrence color="#3d444d" />
    <writeOccurrence color="#484f58" />
    <removedLine color="#f85149" />
    <findScope color="#3d444d" />
    <searchResult color="#3d444d" />
    <filteredSearchResult color="#3d444d" />

    <!-- BASIC SYNTAX ELEMENTS -->
    <comment color="#8b949e" italic="true" />
    <multiLineComment color="#8b949e" italic="true" />
    <taskTag color="#ff7b72" bold="true" />
    <keyword color="#ff7b72" bold="true" />
    <number color="#a5f3fc" />
    <string color="#a5f3fc" />
    <bracket color="#ffd700" />
    <operator color="#f0f6fc" />

    <!-- OBJECT-ORIENTED CONSTRUCTS -->
    <class color="#ffd700" bold="true" />
    <abstractClass color="#ffc649" />
    <interface color="#ffb347" />
    <enum color="#7ee787" />
    <annotation color="#ffa657" />

    <!-- METHODS & FUNCTIONS -->
    <method color="#d2a8ff" />
    <staticMethod color="#79c0ff" />
    <abstractMethod color="#d2a8ff" />
    <inheritedMethod color="#b392f0" />
    <methodDeclaration color="#d2a8ff" />

    <!-- VARIABLES & FIELDS -->
    <field color="#ffa657" />
    <staticField color="#ffd700" bold="true" />
    <constant color="#ffdf00" bold="true" />
    <localVariable color="#f0f6fc" />
    <localVariableDeclaration color="#f0f6fc" />
    <argument color="#ffc649" />

    <!-- GENERIC PROGRAMMING -->
    <templateParameter color="#56d4dd" />
    <templateArgument color="#56d4dd" />

    <!-- DOCUMENTATION -->
    <doc color="#8b949e" italic="true" />
    <docTag color="#ffa657" />
    <docLink color="#79c0ff" />
    <docXmlTag color="#ffa657" />

    <!-- SPECIAL STATES -->
    <deprecated color="#6e7681" strikethrough="true" />

    <!-- LANGUAGE-SPECIFIC: XML -->
    <xmlTag color="#7ee787" />
    <xmlAttribute color="#ffa657" />

</colorTheme>