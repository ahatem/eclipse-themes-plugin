<?xml version="1.0" encoding="utf-8"?>
<colorTheme ect-id="a1174530-ef75-414d-86f0-210f08b2c2e0" id="4006" name="Visual Studio Light" modified="2024-09-21" author="Eclipse Themes" type="light">

    <!-- CORE EDITOR COLORS -->
    <foreground color="#000000" />
    <background color="#FFFFFF" />
    <selectionBackground color="#ADD6FF" />
    <currentLine color="#EEEEEE" />
    <lineNumber color="#237893" />

    <!-- EDITOR FEATURES & NAVIGATION -->
    <occurrence color="#D5D5D5" />
    <writeOccurrence color="#D5D5D5" />
    <removedLine color="#CD3131" />
    <searchResult color="#D5D5D5" />
    <filteredSearchResult color="#D5D5D5" />

    <!-- BASIC SYNTAX ELEMENTS -->
    <comment color="#008000" />
    <multiLineComment color="#008000" />
    <taskTag color="#008000" />
    <keyword color="#0000FF" />
    <number color="#098658" />
    <string color="#A31515" />
    <bracket color="#000000" />
    <operator color="#000000" />

    <!-- OBJECT-ORIENTED CONSTRUCTS -->
    <class color="#267F99" />
    <interface color="#267F99" />
    <enum color="#267F99" />
    <annotation color="#795E26" />

    <!-- METHODS & FUNCTIONS -->
    <method color="#795E26" />
    <staticMethod color="#795E26" />
    <inheritedMethod color="#795E26" />
    <methodDeclaration color="#795E26" />

    <!-- VARIABLES & FIELDS -->
    <field color="#001080" />
    <staticField color="#001080" />
    <constant color="#0070C1" />
    <localVariable color="#001080" />
    <localVariableDeclaration color="#001080" />
    <argument color="#001080" />

    <!-- GENERIC PROGRAMMING -->
    <templateParameter color="#267F99" />
    <templateArgument color="#267F99" />

    <!-- DOCUMENTATION -->
    <doc color="#008000" />
    <docTag color="#0000FF" />
    <docLink color="#0000FF" />
    <docXmlTag color="#0000FF" />

    <!-- SPECIAL STATES -->
    <deprecated color="#808080" strikethrough="true" />

    <!-- LANGUAGE-SPECIFIC: XML -->
    <xmlTag color="#0000FF" />
    <xmlAttribute color="#001080" />

</colorTheme>