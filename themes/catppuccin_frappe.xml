<?xml version="1.0" encoding="utf-8"?>
<colorTheme id="9004" name="Catppuccin Frappé" modified="2025-09-22" author="Eclipse Themes" type="dark" >
    
    <!-- Background and Basic Colors -->
    <background color="#303446" />
    <foreground color="#c6d0f5" />
    <currentLine color="#3B3F52" />
    <lineNumber color="#838ba7" />
    <selectionBackground color="#494E63" />
    <selectionForeground color="#c6d0f5" />
    
    <!-- Occurrences and Search -->
    <searchResultIndication color="#674b59" />
    <filteredSearchResultIndication color="#506373" />
    <occurrenceIndication color="#44495D" />
    <writeOccurrenceIndication color="#424C68" />
    
    <!-- Comments and Documentation -->
    <singleLineComment color="#949cbb" italic="true" />
    <multiLineComment color="#949cbb" italic="true" />
    <commentTaskTag color="#ca9ee6" bold="true" />
    <javadoc color="#949cbb" italic="true" />
    <javadocTag color="#ca9ee6" bold="true" />
    <javadocKeyword color="#ca9ee6" />
    <javadocLink color="#8caaee" />
    
    <!-- Java Language Elements -->
    <class color="#e5c890" italic="true" />
    <interface color="#e5c890" italic="true" />
    <abstractClass color="#e5c890" italic="true" />
    <enum color="#e5c890" italic="true" />
    <method color="#8caaee" italic="true" />
    <methodDeclaration color="#8caaee" italic="true" />
    <inheritedMethod color="#8caaee" italic="true" />
    <staticMethod color="#8caaee" italic="true" />
    <abstractMethod color="#8caaee" italic="true" />
    
    <!-- Variables and Fields -->
    <localVariable color="#c6d0f5" />
    <localVariableDeclaration color="#c6d0f5" />
    <field color="#c6d0f5" />
    <staticField color="#c6d0f5" italic="true" />
    <staticFinalField color="#ef9f76" bold="true" italic="true" />
    <parameterVariable color="#ea999c" italic="true" />
    <constant color="#ef9f76" />
    
    <!-- Language Constructs -->
    <keyword color="#ca9ee6" />
    <operator color="#81c8be" />
    <bracket color="#949cbb" />
    <number color="#ef9f76" />
    <string color="#a6d189" />
    <annotation color="#ef9f76" />
    
    <!-- Generic/Template Types -->
    <typeArgument color="#99d1db" />
    <typeParameter color="#99d1db" />
    
    <!-- Special Cases -->
    <deprecatedMember color="#c6d0f5" strikethrough="true" />
    
    <!-- XML Support -->
    <xmlTag color="#8caaee" />
    <xmlAttribute color="#e5c890" />
    <xmlComment color="#949cbb" />
    
    <!-- Additional Editor Support -->
    <sourceHoverBackground color="#292c3c" />
    <deletionIndication color="#e78284" />
    <findScope color="#292c3c" />
    
</colorTheme>