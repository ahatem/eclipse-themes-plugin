<colorTheme id="9008" name="Jupyter" modified="2025-09-22" author="Eclipse Themes" type="light">
    
    <!-- Background and Basic Colors -->
    <background color="#ffffff" />
    <foreground color="#212121" />
    <currentLine color="#FDF0E2" />
    <lineNumber color="#aaaaaa" />
    <selectionBackground color="#FDF0E2" />
    <selectionForeground color="#212121" />
    
    <!-- Occurrences and Search -->
    <searchResultIndication color="#FDF0E2" />
    <filteredSearchResultIndication color="#FDF0E2" />
    <occurrenceIndication color="#FDF0E2" />
    <writeOccurrenceIndication color="#FDF0E2" />
    
    <!-- Comments and Documentation -->
    <singleLineComment color="#408080" italic="true" />
    <multiLineComment color="#408080" italic="true" />
    <commentTaskTag color="#008000" bold="true" />
    <javadoc color="#408080" />
    <javadocTag color="#008000" bold="true" />
    <javadocKeyword color="#008000" />
    <javadocLink color="#0000FF" />
    
    <!-- Java Language Elements -->
    <class color="#0000FF" />
    <interface color="#0000FF" />
    <abstractClass color="#0000FF" />
    <enum color="#0000FF" />
    <method color="#0000FF" />
    <methodDeclaration color="#0000FF" />
    <inheritedMethod color="#0000FF" />
    <staticMethod color="#0000FF" italic="true" />
    <abstractMethod color="#0000FF" />
    
    <!-- Variables and Fields -->
    <localVariable color="#212121" />
    <localVariableDeclaration color="#212121" />
    <field color="#212121" />
    <staticField color="#212121" italic="true" />
    <staticFinalField color="#BC7A00" bold="true" italic="true" />
    <parameterVariable color="#212121" />
    <constant color="#BC7A00" />
    
    <!-- Language Constructs -->
    <keyword color="#008000" bold="true" />
    <operator color="#aa22ff" />
    <bracket color="#212121" />
    <number color="#BC7A00" />
    <string color="#BA2121" />
    <annotation color="#AA22FF" />
    
    <!-- Generic/Template Types -->
    <typeArgument color="#0000FF" />
    <typeParameter color="#0000FF" />
    
    <!-- Special Cases -->
    <deprecatedMember color="#212121" strikethrough="true" />
    
    <!-- XML Support -->
    <xmlTag color="#008000" bold="true" />
    <xmlAttribute color="#7D9029" />
    <xmlComment color="#408080" />
    
    <!-- Additional Editor Support -->
    <sourceHoverBackground color="#ffffff" />
    <deletionIndication color="#c7254e" />
    <findScope color="#FDF0E2" />
    
</colorTheme>