<?xml version="1.0" encoding="utf-8"?>
<colorTheme id="9011" name="Quiet Light" modified="2025-09-22" author="Eclipse Themes" type="light">
    
    <!-- Background and Basic Colors -->
    <background color="#F5F5F5" />
    <foreground color="#333333" />
    <currentLine color="#E4F6D4" />
    <lineNumber color="#6D705B" />
    <selectionBackground color="#C9D0D9" />
    <selectionForeground color="#333333" />
    
    <!-- Occurrences and Search -->
    <searchResultIndication color="#BF9CAC" />
    <filteredSearchResultIndication color="#E3D7DC" />
    <occurrenceIndication color="#C9D0D9" />
    <writeOccurrenceIndication color="#C9D0D9" />
    
    <!-- Comments and Documentation -->
    <singleLineComment color="#AAAAAA" italic="true" />
    <multiLineComment color="#AAAAAA" italic="true" />
    <commentTaskTag color="#448C27" bold="true" />
    <javadoc color="#448C27" />
    <javadocTag color="#7A3E9D" bold="true" />
    <javadocKeyword color="#4B69C6" />
    <javadocLink color="#4B69C6" />
    
    <!-- Java Language Elements -->
    <class color="#7A3E9D" bold="true" />
    <interface color="#7A3E9D" bold="true" />
    <abstractClass color="#7A3E9D" bold="true" />
    <enum color="#7A3E9D" bold="true" />
    <method color="#AA3731" bold="true" />
    <methodDeclaration color="#AA3731" bold="true" />
    <inheritedMethod color="#AA3731" bold="true" />
    <staticMethod color="#AA3731" bold="true" italic="true" />
    <abstractMethod color="#AA3731" bold="true" />
    
    <!-- Variables and Fields -->
    <localVariable color="#7A3E9D" />
    <localVariableDeclaration color="#7A3E9D" />
    <field color="#7A3E9D" />
    <staticField color="#7A3E9D" italic="true" />
    <staticFinalField color="#9C5D27" bold="true" italic="true" />
    <parameterVariable color="#333333" />
    <constant color="#9C5D27" />
    
    <!-- Language Constructs -->
    <keyword color="#4B69C6" />
    <operator color="#777777" />
    <bracket color="#777777" />
    <number color="#9C5D27" />
    <string color="#448C27" />
    <annotation color="#7A3E9D" />
    
    <!-- Generic/Template Types -->
    <typeArgument color="#7A3E9D" />
    <typeParameter color="#7A3E9D" />
    
    <!-- Special Cases -->
    <deprecatedMember color="#333333" strikethrough="true" />
    
    <!-- XML Support -->
    <xmlTag color="#4B69C6" />
    <xmlAttribute color="#8190A0" italic="true" />
    <xmlComment color="#AAAAAA" />
    
    <!-- Additional Editor Support -->
    <sourceHoverBackground color="#F5F5F5" />
    <deletionIndication color="#C73D20" />
    <findScope color="#E4F6D4" />
    
</colorTheme>