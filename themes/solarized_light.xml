<?xml version="1.0" encoding="utf-8"?>
<colorTheme id="4004" name="Solarized Light" modified="2024-09-21" author="Eclipse Themes" type="light">
    
    <!-- Background and Basic Colors -->
    <background color="#FDF6E3" />
    <foreground color="#657B83" />
    <currentLine color="#EEE8D5" />
    <lineNumber color="#93A1A1" />
    <selectionBackground color="#E3D8BD" />
	<selectionForeground color="#657B83" />
    
    <!-- Occurrences and Search -->
    <searchResultIndication color="#ded8c7" />
    <filteredSearchResultIndication color="#ded8c7" />
    <occurrenceIndication color="#ded8c7" />
    <writeOccurrenceIndication color="#ded8c7" />
    
    <!-- Comments and Documentation -->
    <singleLineComment color="#93A1A1" />
    <multiLineComment color="#93A1A1" />
    <commentTaskTag color="#D33682" bold="true" />
    <javadoc color="#93A1A1" />
    <javadocTag color="#D33682" />
    <javadocKeyword color="#D33682" />
    
    <!-- Java Language Elements -->
    <class color="#B58900" />
    <interface color="#B58900" />
    <enum color="#859900" />
    <method color="#268BD2" />
    <methodDeclaration color="#268BD2" />
    <inheritedMethod color="#268BD2" />
    <staticMethod color="#268BD2" />
    
    <!-- Variables and Fields -->
    <localVariable color="#6C71C4" />
    <localVariableDeclaration color="#6C71C4" />
    <field color="#6C71C4" />
    <staticField color="#CB4B16" />
    <staticFinalField color="#CB4B16" />
    <parameterVariable color="#6C71C4" />
    <constant color="#CB4B16" />
    
    <!-- Language Constructs -->
    <keyword color="#859900" />
    <operator color="#657B83" />
    <bracket color="#657B83" />
    <number color="#D33682" />
    <string color="#2AA198" />
    <annotation color="#CB4B16" />
    
    <!-- Generic/Template Types -->
    <typeArgument color="#6C71C4" />
    <typeParameter color="#6C71C4" />
    
    <!-- Special Cases -->
    <deprecatedMember color="#93A1A1" strikethrough="true" />
    
    <!-- XML Support -->
    <xmlTag color="#268BD2" />
    <xmlAttribute color="#B58900" />
    <xmlComment color="#93A1A1" />
    <xmlDirective color="#6C71C4" />
    
    <!-- Additional Editor Support -->
    <sourceHoverBackground color="#EEE8D5" />
    <deletionIndication color="#DC322F" />
    
</colorTheme>
