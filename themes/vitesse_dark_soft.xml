<?xml version="1.0" encoding="utf-8"?>
<colorTheme id="6006" name="Vitesse Dark Soft" modified="2024-09-21" author="Eclipse Themes" type="dark">
    
    <!-- Background and Basic Colors -->
    <background color="#222222" />
    <foreground color="#dbd7ca" />
    <currentLine color="#292929" />
    <lineNumber color="#959da5" />
    <selectionBackground color="#353535" />
    <selectionForeground color="#dbd7ca" />
    
    <!-- Editor and UI Elements -->
    <searchResultIndication color="#e6cc77" />
    <filteredSearchResultIndication color="#e6cc77" />
    <occurrenceIndication color="#2f2f2f" />
    <writeOccurrenceIndication color="#3a3a3a" />
    
    <!-- Comments and Documentation -->
    <singleLineComment color="#758575" italic="true" />
    <multiLineComment color="#758575" italic="true" />
    <commentTaskTag color="#4d9375" bold="true" />
    <javadoc color="#758575" italic="true" />
    <javadocTag color="#5d99a9" />
    <javadocKeyword color="#5d99a9" />
    <javadocLink color="#6394bf" />
    
    <!-- Java Language Elements -->
    <class color="#6872ab" />
    <interface color="#5d99a9" />
    <abstractClass color="#6872ab" />
    <enum color="#c99076" />
    <method color="#80a665" />
    <methodDeclaration color="#80a665" />
    <inheritedMethod color="#80a665" />
    <staticMethod color="#80a665" italic="true" />
    <abstractMethod color="#80a665" />
    
    <!-- Variables and Fields -->
    <localVariable color="#bd976a" />
    <localVariableDeclaration color="#bd976a" />
    <field color="#bd976a" />
    <staticField color="#bd976a" italic="true" />
    <staticFinalField color="#c99076" bold="true" />
    <parameterVariable color="#dbd7ca" />
    <constant color="#c99076" />
    
    <!-- Language Constructs -->
    <keyword color="#4d9375" />
    <operator color="#666666" />
    <bracket color="#666666" />
    <number color="#4c9a91" />
    <string color="#c98a7d" />
    <annotation color="#b8a965" />
    
    <!-- Generic/Template Types -->
    <typeArgument color="#5da994" />
    <typeParameter color="#5da994" />
    
    <!-- Special Cases -->
    <deprecatedMember color="#758575" strikethrough="true" />
    
    <!-- XML Support -->
    <xmlTag color="#4d9375" />
    <xmlAttribute color="#bd976a" />
    <xmlComment color="#758575" italic="true" />
    
    <!-- Additional Editor Support -->
    <sourceHoverBackground color="#292929" />
    <deletionIndication color="#cb7676" />
    <findScope color="#353535" />
    
    <!-- Error and Warning Colors -->
    <error color="#cb7676" />
    <warning color="#d4976c" />
    
</colorTheme>